generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. ENUMERAÇÕES
enum TipoPerfil {
  Admin
  Vet
  Staff
  Rececao
}

enum EstadoServico {
  Feito
  Pendente
  Finalizado
  Falhado
}

enum EstadoVacina {
  Valido
  Caducado
}

enum EstadoClinico {
  Saudavel
  Quarentena
}

enum EstadoReserva {
  Pendente
  CheckIn
  CheckOut
  Cancelada
}

enum EstadoBox {
  Suja
  Higienizada
}

enum TipoServico {
  Grooming
  Passeio
  Adestramento
  Alimentacao
}

// ==========================================
// 2. ENTIDADES BASE E HERANÇA
// ==========================================
model Utilizador {
  idUtilizador String @id @default(uuid())
  nome         String
  email        String @unique
  password     String

  tutor       Tutor?
  funcionario Funcionario?
}

model Tutor {
  nif      String @id
  contacto String

  utilizadorId String     @unique
  utilizador   Utilizador @relation(fields: [utilizadorId], references: [idUtilizador], onDelete: Cascade)

  // Exigência do Prisma: não cria coluna na BD, serve apenas para o código saber 
  // que o Animal tem a chave estrangeira (tutorNif) a apontar para aqui.
  animais Animal[]
}

model Funcionario {
  idFuncionario String     @id @default(uuid())
  perfil        TipoPerfil

  utilizadorId String     @unique
  utilizador   Utilizador @relation(fields: [utilizadorId], references: [idUtilizador], onDelete: Cascade)

  // Relações clínicas
  prescricoes       Prescricao[]
  logsMedicos       LogMedicacao[]
  tarefasAtribuidas Servico[]
}

// ==========================================
// 3. ENTIDADES DE DOMÍNIO E RELACIONAMENTOS
// ==========================================
model Animal {
  idAnimal    String        @id @default(uuid())
  nome        String
  raca        String?
  reatividade String
  microchip   String        @unique
  estado      EstadoClinico @default(Saudavel)
  check       Boolean       @default(false)
  tipoTrela   String?       @default("Normal")

  racaoId    String? // Guarda o ID do Item de Stock da Ração que o cão come
  doseDiaria Float? // Quantidade a descontar de cada vez que a tarefa for concluída

  // Os animais é que têm tutor (Chave Estrangeira aqui)
  tutorNif String
  tutor    Tutor  @relation(fields: [tutorNif], references: [nif])

  planoVacinal PlanoVacinal?
  reservas     Reserva[] // Exigência Prisma (A FK está na Reserva)
  prescricoes  Prescricao[] // Exigência Prisma (A FK está na Prescricao)
}

model PlanoVacinal {
  idPlano          String       @id @default(uuid())
  dataUltimaVacina DateTime
  documento        String
  isValido         Boolean      @default(false)
  estado           EstadoVacina

  animalId String @unique
  animal   Animal @relation(fields: [animalId], references: [idAnimal], onDelete: Cascade)
}

model Box {
  numero Int @id

  // NOVOS CAMPOS EXCLUSIVOS (Substituem o Tamanho):
  tipo String @default("Não-Reativo")

  estado String @default("Limpa")

  reservas Reserva[]
}

model Reserva {
  idReserva   String        @id @default(uuid())
  dataEntrada DateTime
  dataSaida   DateTime
  valor       Float
  estado      EstadoReserva @default(Pendente)
  termoAceite Boolean       @default(false)

  // A reserva tem animal e tem box (As Chaves Estrangeiras ficam aqui)
  animalId String
  animal   Animal @relation(fields: [animalId], references: [idAnimal])

  boxNumero Int
  box       Box @relation(fields: [boxNumero], references: [numero])

  // A reserva tem a fatura (Fatura não tem referência direta à reserva)
  faturaId String?  @unique
  fatura   Faturas? @relation(fields: [faturaId], references: [idFaturas])

  servicos Servico[] // Exigência Prisma (A FK está no Servico para permitir múltiplos)

  diarioBordo DiarioBordo[]
}

model Servico {
  idServico String        @id @default(uuid())
  data      DateTime
  preco     Float
  tipo      TipoServico
  estado    EstadoServico @default(Pendente)
  descricao String? // NOVO: Descrição do serviço

  reservaId String
  reserva   Reserva @relation(fields: [reservaId], references: [idReserva])

  funcionarioId String?
  funcionario   Funcionario? @relation(fields: [funcionarioId], references: [idFuncionario])
}

model Faturas {
  idFaturas  String @id @default(uuid())
  nifCliente String
  valorTotal Float
  documento  String

  metodoPagamento String @default("Não Definido")

  // Sem referência direta à Reserva, a Reserva é que lhe aponta.
  reserva Reserva?
}

model DiarioBordo {
  idRegisto String   @id @default(uuid())
  descricao String
  timestamp DateTime @default(now())
  fotos     String[]

  reservaId String
  reserva   Reserva @relation(fields: [reservaId], references: [idReserva])
}

// 4. CLÍNICA / MEDICAMENTOS / STOCK
model Stock {
  idItem       String @id @default(uuid())
  nome         String
  quantidade   Int
  limiteAlerta Int

  medicamento Medicamento? // Herança 1:1
  racao       Racao? // Herança 1:1
}

model Medicamento {
  idMedicamento String @id @default(uuid())
  concentracao  Float

  stockId String @unique
  stock   Stock  @relation(fields: [stockId], references: [idItem], onDelete: Cascade)

  linhas LinhaPrescricao[]
}

model Racao {
  idRacao String  @id @default(uuid())
  marca   String? // Opcional, ex: Royal Canin

  stockId String @unique
  stock   Stock  @relation(fields: [stockId], references: [idItem], onDelete: Cascade)
}

model Prescricao {
  idPrescricao String   @id @default(uuid())
  data         DateTime

  animalId      String
  animal        Animal      @relation(fields: [animalId], references: [idAnimal])
  funcionarioId String
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [idFuncionario])

  // Uma prescrição tem várias linhas (medicamentos diferentes)
  linhas LinhaPrescricao[]
}

model LinhaPrescricao {
  idLinha    String @id @default(uuid())
  dosagem    Float
  frequencia String

  totalDoses Int     @default(1)
  ativa      Boolean @default(true)

  prescricaoId String
  prescricao   Prescricao @relation(fields: [prescricaoId], references: [idPrescricao], onDelete: Cascade)

  medicamentoId String
  medicamento   Medicamento @relation(fields: [medicamentoId], references: [idMedicamento])

  logsAdministracao LogMedicacao[]
}

model LogMedicacao {
  idLog     String   @id @default(uuid())
  timestamp DateTime @default(now())

  funcionarioId String
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [idFuncionario])

  linhaId String
  linha   LinhaPrescricao @relation(fields: [linhaId], references: [idLinha], onDelete: Cascade)
}
